{
  "description": "ReorderSections: reverse the section order in a document",
  "initial_vault": "../valid/with-documents",
  "command": {
    "type": "ReorderSections",
    "payload": {
      "document_id": "d0000000-0000-4000-a000-000000000001",
      "section_order": [
        "30000000-0000-4000-a000-000000000003",
        "30000000-0000-4000-a000-000000000002"
      ]
    }
  },
  "expected": {
    "result": "success",
    "assertions": [
      {
        "type": "document_section_at",
        "document_id": "d0000000-0000-4000-a000-000000000001",
        "index": 0,
        "block_id": "30000000-0000-4000-a000-000000000003"
      },
      {
        "type": "document_section_at",
        "document_id": "d0000000-0000-4000-a000-000000000001",
        "index": 1,
        "block_id": "30000000-0000-4000-a000-000000000002"
      },
      {
        "type": "event_emitted",
        "event": "SectionsReordered",
        "document_id": "d0000000-0000-4000-a000-000000000001"
      }
    ]
  }
}
