{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "journal.schema.json",
  "title": "PortableNote Commit Journal",
  "description": "Ephemeral write-ahead log. Present only during an in-flight commit. On vault open, its presence triggers the recovery protocol (§5a of the spec).",
  "type": "object",
  "required": ["expected_checksum", "before_image", "writes"],
  "additionalProperties": false,
  "properties": {
    "expected_checksum": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "The checksum the vault will have after all writes are applied — the 'after' state. Recovery Case A: if actual vault checksum matches this, all writes landed but the manifest write was lost."
    },
    "before_image": {
      "type": "array",
      "description": "Full prior state of every artifact that writes will modify or delete. Applied to undo a partial commit (Case C recovery).",
      "items": {
        "$ref": "#/$defs/before_image_entry"
      }
    },
    "writes": {
      "type": "array",
      "description": "Ordered list of vault writes to apply. Applied in sequence during commit and for redo recovery.",
      "items": {
        "$ref": "./vault-writes.schema.json#/$defs/write"
      }
    }
  },
  "$defs": {
    "before_image_entry": {
      "description": "The prior state of a single artifact before this commit. data is null if the artifact was created by this commit — undo means delete it.",
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "data"],
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "const": "Block" },
            "data": {
              "oneOf": [
                { "$ref": "./block.schema.json" },
                { "type": "null" }
              ]
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "data"],
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "const": "Edge" },
            "data": {
              "oneOf": [
                { "$ref": "./block-graph.schema.json#/$defs/edge" },
                { "type": "null" }
              ]
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "data"],
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "const": "Document" },
            "data": {
              "oneOf": [
                { "$ref": "./document.schema.json" },
                { "type": "null" }
              ]
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "name", "data"],
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "const": "Name" },
            "name": { "type": "string", "minLength": 1 },
            "data": {
              "oneOf": [
                { "type": "string", "format": "uuid" },
                { "type": "null" }
              ]
            }
          }
        }
      ]
    }
  }
}
